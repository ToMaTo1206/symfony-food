<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="turbo-cache-control" content="no-preview">
    <title>{% block title %}Welcome!{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    {% block stylesheets %}
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>
{% block navbar %}

    <nav class="navbar navbar-dark navbar-glass text-secondary shadow-sm">
        <div class="container-fluid">
            <a class="navbar-brand text-secondary" href="{{ path('home') }}">Food</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse mb-3" id="navbarSupportedContent">
                <ul class="navbar-nav me-auto mb-lg-0 gap-2">
                    <hr />
                    <li>
                        <form class="d-flex mt-3 mt-lg-0" role="search" method="GET" action="{{ path('food') }}">
                            <input class="form-control me-2 rounded-pill border-0 shadow-sm" type="search" name="search" placeholder="Rechercher un aliment..." aria-label="Rechercher">

                            <button class="btn btn-secondary text-primary rounded-pill fw-bold px-3" type="submit">
                                🔍
                            </button>
                        </form>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-secondary" href="{{ path('user') }}">Votre profil</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-secondary" href="{{ path('food') }}">Votre frigo</a>
                    </li>
                    <li class="nav-item">
                        {% if app.user %}
                            <a href="{{ path('logout') }}">se déconnecter ?</a>
                        {% endif %}
                    </li>
                </ul>
            </div>
        </div>
    </nav>

{% endblock %}

<main class="container mt-4">

    {% block main %}{% endblock %}

</main>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script data-turbo-cache="false">
    (function() {
        const flashMessages = [
            {% for label, messages in app.flashes %}
            {% for message in messages %}
            { label: '{{ label|e("js") }}', message: '{{ message|e("js") }}' },
            {% endfor %}
            {% endfor %}
        ];

        const displayFlashes = () => {
            if (flashMessages.length === 0) return;

            flashMessages.forEach(flash => {
                Swal.fire({
                    icon: (flash.label === 'danger' || flash.label === 'error') ? 'error' : 'success',
                    title: flash.label === 'success' ? 'Bravo !' : 'Attention',
                    text: flash.message,
                    toast: true,
                    position: 'top-end',
                    timer: 4000,
                    timerProgressBar: true,
                    showConfirmButton: false
                });
            });

            flashMessages.length = 0;
        };

        document.addEventListener('turbo:load', displayFlashes);

        if (document.readyState === 'complete') {
            displayFlashes();
        }
    })();
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
