{% extends 'base.html.twig' %}

{% block title %}Accueil - Food Saver{% endblock %}

{% block main %}
    <div class="container mt-4">

        <div class="mb-5 d-flex flex-column flex-md-row justify-content-around align-items-md-center">

            <div class="text-center text-md-left">
                <h1 class="text-secondary fw-bold display-5">Bonjour, {{ app.user.firstname }} !</h1>
                <p class="text-secondary opacity-75 fs-5 mb-0">Voici le récapitulatif de votre frigo.</p>
            </div>

            <div class="text-center text-md-end mt-4 mt-md-0">
                <a href="{{ path('food') }}" class="btn btn-secondary text-primary btn-lg rounded-pill px-5 py-3 shadow-sm fw-bold fs-5">
                    Ouvrir mon frigo
                </a>
            </div>

        </div>

        <div class="card bg-secondary text-primary border-0 rounded-4 shadow-lg mb-5">

            <div class="card-header bg-transparent border-primary border-opacity-25 p-4 d-flex align-items-center gap-2">
                <h2 class="h4 mb-0 fw-bold">Déjà périmés (À jeter)</h2>
            </div>

            <div class="card-body p-4 p-md-5">

                {% if expiring is empty %}
                    <div class="text-center py-4">
                        <h3 class="h5 fw-bold text-success">Super nouvelle !</h3>
                        <p class="mb-0">Aucun aliment de votre frigo n'est périmé.</p>
                    </div>
                {% else %}
                    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                        {% for aliment in expiring %}
                            {{ include('home/_food_card.html.twig') }}
                        {% endfor %}
                    </div>
                {% endif %}

            </div>
        </div>

        <div class="card bg-secondary text-primary border-0 rounded-4 shadow-lg mb-5">

            <div class="card-header bg-transparent border-primary border-opacity-25 p-4 d-flex align-items-center gap-2">
                <h2 class="h4 mb-0 fw-bold">À consommer d'ici {{ limitDate }} jours</h2>
            </div>

            <div class="card-body p-4 p-md-5">

                {% if expiringSoon is empty %}
                    <div class="text-center py-4">
                        <p class="mb-0">Aucun aliment de votre frigo ne se périme dans les {{ limitDate }} jours.</p>
                    </div>
                {% else %}
                    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                        {% for aliment in expiringSoon %}
                            {{ include('home/_food_card.html.twig') }}
                        {% endfor %}
                    </div>
                {% endif %}

            </div>
        </div>
    </div>
{% endblock %}
