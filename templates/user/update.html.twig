{% extends 'base.html.twig' %}

{% block title %}Modifier mon profil - Food Saver{% endblock %}

{% block main %}
    <div class="row justify-content-center mt-5">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 bg-secondary">
                <div class="card-body p-4 d-flex flex-column text-primary">

                    <h2 class="text-center mb-4 text-primary">Modifier mon profil</h2>

                    {{ form_start(form) }}

                    <div class="row">
                        <div class="col-md-6 text-primary">
                            {{ form_row(form.firstname, {
                                label: 'Prénom',
                            }) }}
                        </div>
                        <div class="col-md-6 text-primary">
                            {{ form_row(form.lastname, {
                                label: 'Nom',
                            }) }}
                        </div>
                    </div>

                    <div class="text-primary">
                        {{ form_row(form.email, {
                            label: 'Adresse email',
                        }) }}
                    </div>

                    <hr class="border-primary opacity-25 my-4">
                    <p class="small text-muted mb-3">Laissez le champ vide si vous ne souhaitez pas modifier votre mot de passe.</p>

                    <div class="text-primary mb-4">
                        {{ form_row(form.plainPassword) }}
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a href="{{ path('user') }}" class="btn btn-outline-primary">
                            Annuler
                        </a>
                        <button type="submit" class="btn btn-primary text-secondary px-4">
                            Enregistrer les modifs 💾
                        </button>
                    </div>

                    {{ form_end(form) }}

                </div>
            </div>
        </div>
    </div>
{% endblock %}
