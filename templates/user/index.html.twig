{% extends 'base.html.twig' %}

{% block title %}Mon Profil - Food Saver{% endblock %}

{% block main %}
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">

                <div class="card shadow-lg border-0 rounded-4 overflow-hidden bg-secondary">

                    <div class="card-header navbar-glass text-white text-center py-5 position-relative">
                        <div class="avatar-circle bg-secondary text-primary shadow-sm mx-auto d-flex align-items-center justify-content-center mb-3">
                        <span class="display-5 fw-bold">
                            {{ app.user.firstname|first|upper }}{{ app.user.lastname|first|upper }}
                        </span>
                        </div>
                        <h2 class="h4 mb-0">{{ app.user.firstname }} {{ app.user.lastname }}</h2>
                        <p class="small opacity-75 mb-0">Membre Food Saver</p>
                    </div>

                    <div class="card-body p-4">

                        <div class="mb-4 text-center">
                            <label class="text-muted small text-uppercase fw-bold ls-1">Email</label>
                            <p class="fs-5 text-dark fw-medium">{{ app.user.email }}</p>
                        </div>

                        <hr class="text-muted opacity-25">

                        <div class="mb-4 text-center d-flex justify-content-around">
                            <a class="btn btn-primary">Modifier ?</a>
                            <a class="btn btn-danger">Supprimer ?</a>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    {# Un petit peu de CSS juste pour l'avatar rond #}
    <style>
        .avatar-circle {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            border: 4px solid rgba(255, 255, 255, 0.3);
        }
        .ls-1 {
            letter-spacing: 1px;
        }
    </style>
{% endblock %}
