{% extends 'base.html.twig' %}

{% block title %}Ajouter un aliment - Food Saver{% endblock %}

{% block main %}
    <div class="row justify-content-center mt-5">
        <div class="col-md-8 col-lg-6">

            <div class="card shadow-lg border-0 bg-secondary text-primary rounded-4">
                <div class="card-body p-4 p-md-5">

                    {# En-tête de la carte #}
                    <div class="text-center mb-4">
                        <h2 class="fw-bold mb-2">Ajouter au frigo</h2>
                        <p class="opacity-75">Renseignez les détails de votre aliment pour suivre sa péremption et éviter le gaspillage.</p>
                    </div>

                    {{ form_start(form) }}

                    <div class="mb-4">
                        {{ form_row(form.name, {
                            'label': 'Nom de l\'aliment',
                            'attr': {'placeholder': 'Ex: Tomates cerises, Yaourt nature...'}
                        }) }}
                    </div>

                    <div class="row mb-2">
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.quantity, {
                                'label': 'Quantité'
                            }) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.weight, {
                                'label': 'Poids (gramme)',
                            }) }}
                        </div>
                    </div>

                    <div class="mb-4">
                        {{ form_row(form.expiryDate, {
                            'label': 'Date de péremption'
                        }) }}
                    </div>

                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mt-5 gap-3">

                        <a href="{{ path('app_food') }}" class="text-decoration-none text-primary opacity-75 fw-medium order-2 order-md-1">
                            ← Annuler et retourner au frigo
                        </a>

                        <button type="submit" class="btn btn-primary btn-lg text-secondary px-5 rounded-pill shadow-sm order-1 order-md-2 w-100 w-md-auto">
                            Ajouter
                        </button>

                    </div>

                    {{ form_end(form) }}

                </div>
            </div>

        </div>
    </div>
{% endblock %}
