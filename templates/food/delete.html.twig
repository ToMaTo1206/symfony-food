{% extends 'base.html.twig' %}

{% block title %}Supprimer un aliment - Food Saver{% endblock %}

{% block main %}
    <div class="row justify-content-center mt-5">
        <div class="col-md-8 col-lg-6">

            <div class="card shadow-lg border-0 bg-secondary text-primary rounded-4">
                <div class="card-body p-4 p-md-5 text-center">

                    <h2 class="fw-bold mb-4">Êtes-vous sûr ?</h2>

                    <h4>{{ food.name }}</h4>

                    <p class="opacity-75 mb-5">
                        Voulez-vous vraiment jeter cet aliment à la poubelle ? <br>
                        Cette action est irréversible.
                    </p>

                    {{ form_start(form) }}

                    <div class="d-flex flex-column flex-md-row justify-content-center gap-3">

                        {{ form_widget(form.cancel, {
                            'label': 'Annuler',
                            'attr': {'class': 'btn btn-outline-primary btn-lg px-4 rounded-pill'}
                        }) }}

                        {{ form_widget(form.delete, {
                            'label': 'Oui, jeter !',
                            'attr': {'class': 'btn btn-danger btn-lg px-4 rounded-pill text-white'}
                        }) }}

                    </div>

                    {{ form_end(form) }}

                </div>
            </div>

        </div>
    </div>
{% endblock %}
